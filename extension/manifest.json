{
  "manifest_version": 3,

  "name": "YouTube AI",

  "version": "1.0",

  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "sidePanel"
  ],

  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "https://www.youtube.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon128.png",
    "32": "icons/icon128.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html"
  }
}